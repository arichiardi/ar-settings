#!/usr/bin/env bash
#
# Initialize a home directory.
#
# The scripts has to be run from the ar-settings repository.
#
set -euo pipefail

# For skipping sections, use this trick:
#
#   cat >/dev/null <<LABEL
#
# see the brilliant answer here: https://stackoverflow.com/a/45538151

script_path="$(readlink -f "${BASH_SOURCE[0]}")"
script_dir="$(dirname "$script_path")"
repo_root="$(git -C "$script_dir" rev-parse --show-toplevel)"

secret_bin=$repo_root/home/.local/bin/secret

temp_dir=$(mktemp -d -t "ar-init-home.XXXXXXXXXX")

source $repo_root/home/.local/share/ar/helpers.sh

pushd $repo_root/home > /dev/null

echo_info "Creating directories"
mkdir -p $HOME/.local/bin
mkdir -p $HOME/tmp
mkdir -p $HOME/git

find_prefix="find . \( -path ./.bashrc.d -o -path ./.profile.d \) -prune -o \("
find_suffix="-not -type d -not -name '.bashrc' -not -name '.bash_profile' -not -name '.bash_aliases' -not -name '.profile' \)"
    
find_files_cmd="$find_prefix -not -name *.enc -not -name *.gpg ${find_suffix} -print0"

files=()
while IFS= read -r -d '' file; do
    files+=("$file")
done < <(
    eval "$find_files_cmd"
)

echo_debug "The files are:"
for file in "${files[@]}"; do
  echo_debug "- $file"
done

init_normal_files "${files[@]}"

echo_info "Making $HOME/.local/bin files executable"
find "$HOME/.local/bin" -type f -and -not -executable -exec chmod u+x {} ';'

find_encrypted_cmd="$find_prefix \( -name *.enc -or -name *.gpg \) ${find_suffix} -print0"

encrypted_files=()
while IFS= read -r -d '' file; do
    encrypted_files+=("$file")
done < <(
    eval "$find_encrypted_cmd"
)

echo_debug "Encrypted files are:"
for file in "${encrypted_files[@]}"; do
  echo_debug "- $file"
done

init_encrypted_files "${encrypted_files[@]}"

popd > /dev/null
