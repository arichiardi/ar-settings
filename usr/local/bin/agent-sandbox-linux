#!/usr/bin/env bash
# agent-sandbox-linux - run a command inside a bubblewrap sandbox.
#
# Env vars:
#   SANDBOX_AGENT_ENV_WHITELIST  - space-delimited list of env var names passed into the sandbox.
#   SANDBOX_AGENT_DIR_RW_WHITELIST - space-delimited list of host directories bind-mounted RW.
#
set -euo pipefail

# Read from environment, default to empty.
SANDBOX_AGENT_ENV_WHITELIST="${SANDBOX_AGENT_ENV_WHITELIST:-}"
SANDBOX_AGENT_DIR_RW_WHITELIST="${SANDBOX_AGENT_DIR_RW_WHITELIST:-}"

echo_info() { echo "ℹ️ $*"; }
echo_warn() { echo "⚠️ $*" >&2; }
echo_error() { echo "❌ $*" >&2; }

if ! command -v bwrap >/dev/null 2>&1; then
    echo_error "bwrap not found. Install bubblewrap." >&2
    exit 1
fi

init_agent_environment() {
    local venv_path="$HOME/.local/share/venv/mcp/bin/activate"
    if [[ -f "$venv_path" ]]; then
        . "$venv_path" || echo_warn "failed to source $venv_path"
    else
        echo_warn "virtual-env activation script not found at $venv_path"
    fi
}

bwrap_args=(
    --unshare-uts
    --unshare-cgroup
    --share-net
    --bind "/run/user/$(id -u)" "/run/user/$(id -u)"
    --tmpfs /tmp
    --dev-bind /dev /dev
    --proc /proc
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind /lib /lib
    --ro-bind /lib64 /lib64
    --ro-bind "$HOME" "$HOME"
    --ro-bind /etc/ssl /etc/ssl
    --ro-bind /usr/share/ca-certificates /usr/share/ca-certificates
    --ro-bind /etc/ca-certificates /etc/ca-certificates
    --dir /var
    --symlink ../tmp var/tmp
    --ro-bind /etc/resolv.conf /etc/resolv.conf
    --die-with-parent
    --dir /etc
    --bind-data 11 /etc/passwd
    --bind-data 12 /etc/group
)

for dir in $SANDBOX_AGENT_DIR_RW_WHITELIST; do
    if [[ -d "$dir" ]]; then
        bwrap_args+=( --bind "$dir" "$dir" )
    else
        echo_warn "Bind skipped: $dir does not exist"
    fi
done

_gnupg_setup=false
if [[ -d "$HOME/.gnupg" ]]; then
    bwrap_args+=( --tmpfs "$HOME/.gnupg" )
    _gnupg_setup=true
    for path in "$HOME/.gnupg/pubring.kbx" "$HOME/.gnupg/trustdb.gpg" \
                "$HOME/.gnupg/gpg.conf" "$HOME/.gnupg/private-keys-v1.d"; do
        if [[ -e "$path" ]]; then
            bwrap_args+=( --ro-bind "$path" "$path" )
        fi
    done
    for socket in "$HOME/.gnupg/S.gpg-agent" "$HOME/.gnupg/S.gpg-agent.browser" \
                  "$HOME/.gnupg/S.gpg-agent.extra" "$HOME/.gnupg/S.gpg-agent.ssh"; do
        if [[ -e "$socket" ]]; then
            bwrap_args+=( --bind "$socket" "$socket" )
        fi
    done
fi

_ssh_setup=false
if [[ -d "$HOME/.ssh" ]]; then
    bwrap_args+=( --tmpfs "$HOME/.ssh" )
    _ssh_setup=true
    for path in "$HOME/.ssh/config" "$HOME/.ssh/authorized_keys"; do
        if [[ -e "$path" ]]; then
            bwrap_args+=( --ro-bind "$path" "$path" )
        fi
    done
    for path in "$HOME/.ssh/known_hosts"; do
        if [[ -e "$path" ]]; then
            bwrap_args+=( --bind "$path" "$path" )
        fi
    done
    for pubkey in "$HOME/.ssh"/*.pub; do
        if [[ -f "$pubkey" ]]; then
            bwrap_args+=( --ro-bind "$pubkey" "$pubkey" )
        fi
    done
fi

for path in "$HOME/.gnupg/secring.gpg" "$HOME/.config/gh/hosts.yml"; do
    if [[ -d "$path" ]]; then
        bwrap_args+=( --tmpfs "$path" )
    elif [[ -f "$path" ]]; then
        bwrap_args+=( --ro-bind /dev/null "$path" )
    fi
done

for var in $SANDBOX_AGENT_ENV_WHITELIST; do
    if [[ -n "${!var:-}" ]]; then
        bwrap_args+=( "--setenv" "$var" "${!var}" )
    fi
done

echo_info "Sandbox env: $SANDBOX_AGENT_ENV_WHITELIST"

GIT_TERMINAL_PROMPT=${GIT_TERMINAL_PROMPT:-0}

_pw="root:x:0:0:root:/root:/bin/bash
${USER}:x:${UID}:${UID}::${HOME}:${SHELL:-/bin/bash}
nobody:x:65534:65534:nobody:/home:/usr/bin/nologin"
_gr="root:x:0:
${USER}:x:${UID}:
nobody:x:65534:"

init_agent_environment

cmd=$1; shift

if $_gnupg_setup && $_ssh_setup; then
    bwrap "${bwrap_args[@]}" -- /bin/bash -c '
        chmod 700 "$HOME/.gnupg" "$HOME/.ssh"
        exec "$@"
    ' _ "$cmd" "$@" \
        11< <(printf '%s\n' "$_pw") \
        12< <(printf '%s\n' "$_gr")
elif $_gnupg_setup; then
    bwrap "${bwrap_args[@]}" -- /bin/bash -c '
        chmod 700 "$HOME/.gnupg"
        exec "$@"
    ' _ "$cmd" "$@" \
        11< <(printf '%s\n' "$_pw") \
        12< <(printf '%s\n' "$_gr")
elif $_ssh_setup; then
    bwrap "${bwrap_args[@]}" -- /bin/bash -c '
        chmod 700 "$HOME/.ssh"
        exec "$@"
    ' _ "$cmd" "$@" \
        11< <(printf '%s\n' "$_pw") \
        12< <(printf '%s\n' "$_gr")
else
    bwrap "${bwrap_args[@]}" -- "$cmd" "$@" \
        11< <(printf '%s\n' "$_pw") \
        12< <(printf '%s\n' "$_gr")
fi
